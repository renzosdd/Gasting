rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && (
          request.auth.token.email == "renzodogliotti@gmail.com"
          || exists(/databases/$(database)/documents/admins/$(request.auth.uid))
          || exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
        );
    }

    function ownsUserField() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    function ownsResourceUserField() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function ownsNewEntity() {
      return signedIn()
        && request.resource.data.propietarios is list
        && request.auth.uid in request.resource.data.propietarios;
    }

    function ownsExistingEntity() {
      return signedIn()
        && resource.data.propietarios is list
        && request.auth.uid in resource.data.propietarios;
    }

    match /admins/{adminId} {
      allow read: if signedIn() && (request.auth.uid == adminId || isAdmin());
      allow write: if isAdmin();
    }

    match /categorias/{categoriaId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /ubicaciones/{ubicacionId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /gastos/{gastoId} {
      allow create: if ownsUserField();
      allow read, delete: if ownsResourceUserField();
      allow update: if ownsResourceUserField() && ownsUserField();
    }

    match /subcategoria_sugerencias/{sugerenciaId} {
      allow create: if ownsUserField();
      allow read: if isAdmin() || ownsResourceUserField();
      allow update, delete: if isAdmin();
    }

    match /categoria_sugerencias/{sugerenciaId} {
      allow create: if ownsUserField();
      allow read: if isAdmin() || ownsResourceUserField();
      allow update, delete: if isAdmin();
    }

    match /vehiculos/{vehiculoId} {
      allow create: if ownsNewEntity();
      allow read, delete: if ownsExistingEntity();
      allow update: if ownsExistingEntity() && ownsNewEntity();
    }

    match /hogares/{hogarId} {
      allow create: if ownsNewEntity();
      allow read, delete: if ownsExistingEntity();
      allow update: if ownsExistingEntity() && ownsNewEntity();
    }

    match /tarjetas/{tarjetaId} {
      allow create: if ownsNewEntity();
      allow read, delete: if ownsExistingEntity();
      allow update: if ownsExistingEntity() && ownsNewEntity();
    }
  }
}
