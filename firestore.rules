rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && (
          request.auth.token.email == "renzodogliotti@gmail.com"
          || exists(/databases/$(database)/documents/admins/$(request.auth.uid))
          || exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
        );
    }

    function ownsUserField() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    function ownsResourceUserField() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function ownsNewEntity() {
      return signedIn()
        && request.resource.data.propietarios is list
        && request.auth.uid in request.resource.data.propietarios;
    }

    function ownsExistingEntity() {
      return signedIn()
        && resource.data.propietarios is list
        && request.auth.uid in resource.data.propietarios;
    }

    function sharedExistingHome() {
      return signedIn()
        && resource.data.miembrosEmails is list
        && request.auth.token.email in resource.data.miembrosEmails;
    }

    function ownsBudget() {
      return signedIn()
        && request.resource.data.miembros is list
        && request.auth.uid in request.resource.data.miembros;
    }

    function ownsExistingBudget() {
      return signedIn()
        && resource.data.miembros is list
        && request.auth.uid in resource.data.miembros;
    }

    match /admins/{adminId} {
      allow read: if signedIn() && (request.auth.uid == adminId || isAdmin());
      allow write: if isAdmin();
    }

    match /usuarios/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    match /categorias/{categoriaId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /ubicaciones/{ubicacionId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /gastos/{gastoId} {
      allow create: if ownsUserField();
      allow read, delete: if ownsResourceUserField() || isAdmin();
      allow update: if isAdmin() || (ownsResourceUserField() && ownsUserField());
    }

    match /importaciones/{importacionId} {
      allow create: if ownsUserField();
      allow read, delete: if ownsResourceUserField();
      allow update: if ownsResourceUserField() && ownsUserField();
    }

    match /subcategoria_sugerencias/{sugerenciaId} {
      allow create: if ownsUserField();
      allow read: if isAdmin() || ownsResourceUserField();
      allow update, delete: if isAdmin();
    }

    match /categoria_sugerencias/{sugerenciaId} {
      allow create: if ownsUserField();
      allow read: if isAdmin() || ownsResourceUserField();
      allow update, delete: if isAdmin();
    }

    match /reglas_categorizacion/{reglaId} {
      allow create: if ownsUserField();
      allow read, delete: if ownsResourceUserField();
      allow update: if ownsResourceUserField() && ownsUserField();
    }

    match /reglas_categorizacion_globales/{reglaId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /vehiculos/{vehiculoId} {
      allow create: if ownsNewEntity();
      allow read, delete: if ownsExistingEntity();
      allow update: if ownsExistingEntity() && ownsNewEntity();
    }

    match /hogares/{hogarId} {
      allow create: if ownsNewEntity();
      allow read: if ownsExistingEntity() || sharedExistingHome();
      allow delete: if ownsExistingEntity();
      allow update: if ownsExistingEntity() && ownsNewEntity();
    }

    match /tarjetas/{tarjetaId} {
      allow create: if ownsNewEntity();
      allow read, delete: if ownsExistingEntity();
      allow update: if ownsExistingEntity() && ownsNewEntity();
    }

    match /presupuestos/{presupuestoId} {
      allow create: if ownsBudget();
      allow read, delete: if ownsExistingBudget() || isAdmin();
      allow update: if isAdmin() || (ownsExistingBudget() && ownsBudget());
    }

    match /producto_precios/{precioId} {
      allow create: if ownsUserField();
      allow read, update, delete: if ownsResourceUserField();
    }

    match /producto_precios_agregados/{agregadoId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
  }
}
